# ─────────────────────────────────────────────────────────────────────────────
# KULT Platform — Contracts Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# RPC endpoint for the target network (e.g. ZeroG mainnet, Alchemy, Infura)
BLOCKCHAIN_RPC_URL=

# EVM chain ID for the target network
# 31337 = Hardhat local | 1 = Ethereum mainnet
CHAIN_ID=

# Private key of the deployer wallet (hex, without 0x prefix is also accepted)
# This account pays for deployment gas.
DEPLOYER_PRIVATE_KEY=

# The backend operator EOA address.
# This address is granted the "operator" role on AgentRegistry, Treasury
# and Settlement contracts and is used by the KULT backend service.
OPERATOR_ADDRESS=

# Etherscan-compatible API key for contract verification (verify.ts).
# Leave blank if the network does not support verification.
ETHERSCAN_API_KEY=
