# ─── Version Control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Dependencies (will be installed fresh inside container) ──────────────────
**/node_modules
**/.pnp
**/.pnp.js

# ─── Build outputs (will be built inside container) ───────────────────────────
**/dist
**/build
**/*.tsbuildinfo

# ─── Environment files (never bake secrets into images) ───────────────────────
.env
.env.*
**/.env
**/.env.*
!**/.env.example

# ─── Hardhat / Contracts (not needed in service containers) ───────────────────
contracts/artifacts
contracts/cache
contracts/typechain-types
contracts/node_modules

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*

# ─── OS / IDE ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea
*.suo
*.sw?

# ─── Test files ───────────────────────────────────────────────────────────────
**/coverage
**/__tests__
**/*.test.ts
**/*.spec.ts

# ─── Docker artifacts ─────────────────────────────────────────────────────────
.docker
docker-compose*.yml

# ─── Keys and secrets ─────────────────────────────────────────────────────────
*.pem
*.key
keystore/

# ─── README and docs (optional - saves a few bytes) ──────────────────────────
README.md
DEPLOY.md
docs/
