# =============================================================================
# KULT PLATFORM — ENVIRONMENT CONFIGURATION EXAMPLE
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# POSTGRESQL (Prisma ORM — used by: gateway, agent-registry, ranking,
# tournament, wallet, settlement services)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://kult_user:kult_pass@localhost:5432/kult_platform?schema=public

# ---------------------------------------------------------------------------
# MONGODB (used by: telemetry-service, model-registry-service)
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://kult_user:kult_pass@localhost:27017/kult_platform?authSource=admin

# ---------------------------------------------------------------------------
# REDIS (used by: arena matchmaking queue, ranking cache, session store)
# ---------------------------------------------------------------------------
REDIS_URL=redis://:kult_redis_pass@localhost:6379/0

# ---------------------------------------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------------------------------------
# Must be at least 32 characters of random data.
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARS_secret_key_here
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# BLOCKCHAIN / EVM
# ---------------------------------------------------------------------------
BLOCKCHAIN_RPC_URL=https://rpc.ankr.com/polygon
CHAIN_ID=137

# Deployed contract addresses (checksummed)
AGENT_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000001
GAME_ECONOMY_CONTRACT=0x0000000000000000000000000000000000000002
TREASURY_CONTRACT=0x0000000000000000000000000000000000000003
SETTLEMENT_CONTRACT=0x0000000000000000000000000000000000000004

# ---------------------------------------------------------------------------
# HOT WALLET ENCRYPTION
# Must be exactly 32 bytes (64 hex chars or 32 ASCII chars).
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_RANDOM_HEX_KEY_00000000000000

# ---------------------------------------------------------------------------
# INTERNAL SERVICE-TO-SERVICE AUTH
# ---------------------------------------------------------------------------
INTERNAL_API_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_FOR_INTERNAL_CALLS

# ---------------------------------------------------------------------------
# EXTERNAL SERVICES
# ---------------------------------------------------------------------------
AI_WARZONE_SERVICE_URL=http://ai-warzone-engine:8080
ZERОГ_STORAGE_ENDPOINT=https://rpc.0g.ai

# ---------------------------------------------------------------------------
# SERVICE PORTS
# All services listen on these ports inside Docker / locally.
# ---------------------------------------------------------------------------
GATEWAY_PORT=3000
AGENT_REGISTRY_PORT=3001
MODEL_REGISTRY_PORT=3002
AVATAR_AI_PORT=3003
ARENA_PORT=3004
RANKING_PORT=3005
TOURNAMENT_PORT=3006
TELEMETRY_PORT=3007
WALLET_PORT=3008
AI_TRANSACTION_PORT=3009
SETTLEMENT_PORT=3010

# ---------------------------------------------------------------------------
# POSTGRES CONTAINER CREDENTIALS (docker-compose only)
# ---------------------------------------------------------------------------
POSTGRES_USER=kult_user
POSTGRES_PASSWORD=kult_pass
POSTGRES_DB=kult_platform

# ---------------------------------------------------------------------------
# MONGO CONTAINER CREDENTIALS (docker-compose only)
# ---------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=kult_user
MONGO_INITDB_ROOT_PASSWORD=kult_pass
MONGO_INITDB_DATABASE=kult_platform

# ---------------------------------------------------------------------------
# REDIS CONTAINER CREDENTIALS (docker-compose only)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=kult_redis_pass

# ---------------------------------------------------------------------------
# RATE LIMITING
# ---------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# ELO / MATCHMAKING
# ---------------------------------------------------------------------------
ELO_K_FACTOR=32
ELO_DEFAULT_RATING=1200
MATCHMAKING_MAX_RATING_DIFF=300
MATCHMAKING_TIMEOUT_MS=30000
