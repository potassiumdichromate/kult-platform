NODE_ENV=development
PORT=3003

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
INTERNAL_API_SECRET=internal-service-secret-key

# AI Warzone Integration (existing system)
AI_WARZONE_SERVICE_URL=http://ai-warzone:8000
AI_WARZONE_API_KEY=warzone-api-key

# Model Registry Service
MODEL_REGISTRY_SERVICE_URL=http://model-registry-service:3002

# BullMQ Training Queue
TRAINING_QUEUE_NAME=avatar-training
TRAINING_CONCURRENCY=2
TRAINING_POLL_INTERVAL_MS=5000
TRAINING_MAX_POLL_ATTEMPTS=120

# Behavior buffer
BEHAVIOR_BUFFER_FLUSH_SIZE=50
BEHAVIOR_BUFFER_TTL_SECONDS=300

LOG_LEVEL=info
