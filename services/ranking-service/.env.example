NODE_ENV=development
PORT=3005

# PostgreSQL
DATABASE_URL=postgresql://kult:kult_password@localhost:5432/kult_ranking

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
INTERNAL_API_SECRET=internal-service-secret-key

# Downstream Services
AGENT_REGISTRY_SERVICE_URL=http://agent-registry-service:3001

# ELO Config
ELO_K_FACTOR_DEFAULT=32
ELO_K_FACTOR_ESTABLISHED=16
ELO_K_FACTOR_MASTER=12
ELO_FLOOR=100
ELO_PROVISIONAL_GAMES=30

# Cache TTLs
LEADERBOARD_CACHE_TTL_SECONDS=30

LOG_LEVEL=info
