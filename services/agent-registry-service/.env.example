# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://kult_user:kult_password@localhost:5432/kult_agents?schema=public

# JWT (shared secret with gateway)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Internal API security
INTERNAL_API_SECRET=your-internal-api-secret-change-in-production

# BullMQ queue names
AGENT_EVENTS_QUEUE=agent-events

# Blockchain
CHAIN_ID=1
RPC_URL=https://mainnet.infura.io/v3/your-infura-key
AGENT_REGISTRY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_OPERATOR_PRIVATE_KEY=your-operator-private-key

# Cache TTLs (seconds)
AGENT_CACHE_TTL=60
LEADERBOARD_CACHE_TTL=30

# Leaderboard
LEADERBOARD_SIZE=100

# Logging
LOG_LEVEL=info
