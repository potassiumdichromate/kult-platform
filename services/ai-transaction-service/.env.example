NODE_ENV=development
PORT=3009

# PostgreSQL
DATABASE_URL=postgresql://kult:kult_password@localhost:5432/kult_transactions

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
INTERNAL_API_SECRET=internal-service-secret-key

# Wallet Service (internal)
WALLET_SERVICE_URL=http://wallet-service:3008

# Blockchain
BLOCKCHAIN_RPC_URL=https://rpc.0g.ai
CHAIN_ID=16600

# Contract Whitelist
GAME_ECONOMY_CONTRACT=0x0000000000000000000000000000000000000000
TREASURY_CONTRACT=0x0000000000000000000000000000000000000000

# Policy Engine Limits
DEFAULT_DAILY_LIMIT_ETH=0.1
DEFAULT_PER_TX_LIMIT_ETH=0.01
GAS_BUFFER_ETH=0.002

# BullMQ
TX_QUEUE_NAME=ai-transactions
TX_QUEUE_CONCURRENCY=5
TX_CONFIRMATION_BLOCKS=2
TX_POLL_INTERVAL_MS=3000
TX_MAX_POLL_ATTEMPTS=60

LOG_LEVEL=info
