NODE_ENV=development
PORT=3006

# PostgreSQL
DATABASE_URL=postgresql://kult:kult_password@localhost:5432/kult_tournaments

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
INTERNAL_API_SECRET=internal-service-secret-key

# Downstream Services
ARENA_SERVICE_URL=http://arena-service:3004
SETTLEMENT_SERVICE_URL=http://settlement-service:3010
WALLET_SERVICE_URL=http://wallet-service:3008

# Tournament Config
MAX_TOURNAMENT_PARTICIPANTS=128
MIN_TOURNAMENT_PARTICIPANTS=4
# Prize distribution (must sum to 100)
PRIZE_PAYOUT_1ST_PCT=50
PRIZE_PAYOUT_2ND_PCT=25
PRIZE_PAYOUT_3RD_PCT=15
PRIZE_PAYOUT_4TH_PCT=10

LOG_LEVEL=info
