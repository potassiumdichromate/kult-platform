# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_MAX_ANON=30
RATE_LIMIT_MAX_AUTH=200
RATE_LIMIT_WINDOW_MS=60000

# Downstream Services
AGENT_REGISTRY_SERVICE_URL=http://agent-registry-service:3001
MODEL_REGISTRY_SERVICE_URL=http://model-registry-service:3002
AVATAR_AI_SERVICE_URL=http://avatar-ai-service:3003
ARENA_SERVICE_URL=http://arena-service:3004
RANKING_SERVICE_URL=http://ranking-service:3005
TOURNAMENT_SERVICE_URL=http://tournament-service:3006
TELEMETRY_SERVICE_URL=http://telemetry-service:3007
WALLET_SERVICE_URL=http://wallet-service:3008
AI_TRANSACTION_SERVICE_URL=http://ai-transaction-service:3009
SETTLEMENT_SERVICE_URL=http://settlement-service:3010

# Internal API
INTERNAL_API_SECRET=your-internal-api-secret-change-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://kultsystem.io

# Blockchain (for wallet signature verification)
CHAIN_ID=1
RPC_URL=https://mainnet.infura.io/v3/your-infura-key

# WebSocket
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_CONNECTIONS=10000

# Logging
LOG_LEVEL=info
