{
  "name": "@kult/shared",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./auth/*": {
      "import": "./dist/auth/*.js",
      "require": "./dist/auth/*.js",
      "types": "./dist/auth/*.d.ts"
    },
    "./database": {
      "import": "./dist/database/prisma.js",
      "require": "./dist/database/prisma.js",
      "types": "./dist/database/prisma.d.ts"
    },
    "./redis": {
      "import": "./dist/redis/client.js",
      "require": "./dist/redis/client.js",
      "types": "./dist/redis/client.d.ts"
    },
    "./blockchain": {
      "import": "./dist/blockchain/client.js",
      "require": "./dist/blockchain/client.js",
      "types": "./dist/blockchain/client.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "require": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "ethers": "^6.11.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.10.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  }
}
